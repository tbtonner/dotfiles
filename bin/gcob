#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "usage: gcob <url> [description...]"
    exit 1
fi

url="$1"
shift

ticket="${url##*/}"

existing=$(git branch --list "${ticket}*" | sed 's/^[* ]*//' | head -1)
if [[ -n "$existing" ]]; then
    echo "Branch '${existing}' already exists, switching to it."
    git checkout "$existing"
    exit 0
fi

if [[ $# -gt 0 ]]; then
    desc=$(IFS=_; printf '%s' "$*")
    git checkout -b "${ticket}_${desc}"
else
    git checkout -b "$ticket"
fi
